<Window x:Class="WpfApp2.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2.Views"
        xmlns:conv="clr-namespace:WpfApp2.Converters"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        Title="Учет личных финансов" Height="700" Width="950"
        Background="#ECEFF4"
        WindowStartupLocation="CenterScreen">

	<Window.Resources>
		<conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
		<conv:AmountToColorConverter x:Key="AmountToColor"/>
		<conv:BalanceToColorConverter x:Key="BalanceToColor"/>
	</Window.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- Заголовок -->
		<TextBlock Text="Учет личных финансов" FontSize="24" FontWeight="SemiBold" Foreground="#2E3440" Margin="20"/>

		<!-- ДАШБОРД -->
		<StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,0,20,16">
			<Border Style="{StaticResource DashboardCard}" MinWidth="180">
				<StackPanel>
					<TextBlock Text="Доходы" Foreground="#4C566A" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
					<TextBlock Text="{Binding TotalIncome, StringFormat='{}{0:N0} ₽'}" Foreground="#A3BE8C" FontWeight="Bold" FontSize="20"/>
				</StackPanel>
			</Border>

			<Border Style="{StaticResource DashboardCard}" MinWidth="180">
				<StackPanel>
					<TextBlock Text="Расходы" Foreground="#4C566A" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
					<TextBlock Text="{Binding TotalExpense, StringFormat='{}{0:N0} ₽'}" Foreground="#BF616A" FontWeight="Bold" FontSize="20"/>
				</StackPanel>
			</Border>

			<Border Style="{StaticResource DashboardCard}" MinWidth="180">
				<StackPanel>
					<TextBlock Text="Баланс" Foreground="#4C566A" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
					<TextBlock Text="{Binding TotalBalance, StringFormat='{}{0:N0} ₽'}" Foreground="{Binding TotalBalance, Converter={StaticResource BalanceToColor}}" FontWeight="Bold" FontSize="20"/>
				</StackPanel>
			</Border>
		</StackPanel>

		<!-- Основной контент -->
		<TabControl Grid.Row="2" Margin="20,0,20,20">
			<TabItem Header="Транзакции">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					<Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16">
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>
							<TextBlock Grid.Row="0" Margin="0,0,0,12">
								<TextBlock.Style>
									<Style TargetType="TextBlock">
										<Setter Property="Text" Value="Новая транзакция:"/>
										<Setter Property="FontWeight" Value="SemiBold"/>
										<Setter Property="Foreground" Value="#2E3440"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding IsEditing}" Value="True">
												<Setter Property="Text" Value="Редактирование транзакции:"/>
												<Setter Property="Foreground" Value="#BF616A"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</TextBlock.Style>
							</TextBlock>

							<Grid Grid.Row="1">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>

								<StackPanel Grid.Column="0" Margin="0,0,16,0">
									<TextBlock Text="Дата" Style="{StaticResource FieldLabel}"/>
									<DatePicker SelectedDate="{Binding Date}" Width="130"/>
								</StackPanel>
								<StackPanel Grid.Column="1" Margin="0,0,16,0">
									<TextBlock Text="Категория" Style="{StaticResource FieldLabel}"/>
									<ComboBox Width="160" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="Name"/>
								</StackPanel>
								<StackPanel Grid.Column="2" Margin="0,0,16,0">
									<TextBlock Text="Сумма, ₽" Style="{StaticResource FieldLabel}"/>
									<TextBox Width="120">
										<TextBox.Text>
											<Binding Path="Amount" UpdateSourceTrigger="PropertyChanged">
												<Binding.ValidationRules>
													<conv:AmountValidationRule/>
												</Binding.ValidationRules>
											</Binding>
										</TextBox.Text>
									</TextBox>
								</StackPanel>

								<StackPanel Grid.Column="3" Margin="0,0,16,0">
									<TextBlock Text="Описание" Style="{StaticResource FieldLabel}"/>
									<TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>
								</StackPanel>

								<StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
									<Button Content="{Binding FormButtonText}" Command="{Binding AddTransactionCommand}" Background="#5E81AC" Foreground="White" Style="{StaticResource ActionButton}"/>
									<Button Content="Отмена" Command="{Binding CancelEditCommand}" Background="#D8DEE9" Foreground="#2E3440" Style="{StaticResource ActionButton}" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>
								</StackPanel>
							</Grid>
						</Grid>
					</Border>

					<TextBlock Grid.Row="1" Text="Выберите строку и нажмите Изм. или Удал." Foreground="#4C566A" FontSize="12" Opacity="0.6" Margin="0,0,0,4" VerticalAlignment="Top"/>

					<DataGrid Grid.Row="1" ItemsSource="{Binding Transactions}" SelectedItem="{Binding SelectedTransaction}" AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#F5F6F8" HeadersVisibility="Column" CanUserAddRows="False" BorderThickness="0" RowHeight="38" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E5E9F0" Margin="0,22,0,0">
						<DataGrid.Columns>
							<DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=\{0:d\}}" Width="100"/>
							<DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="120"/>

							<DataGridTemplateColumn Header="Сумма, ₽" Width="100">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding Amount, StringFormat=\{0:N0\}}" Foreground="{Binding Type, Converter={StaticResource AmountToColor}}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0"/>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>

							<DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>

							<DataGridTemplateColumn Header="Действия" Width="140" IsReadOnly="True">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
											<Button Content="Изм." Command="{Binding DataContext.EditTransactionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" Background="#A3BE8C" Foreground="White" FontSize="11" Padding="10,4" Margin="2,0" Style="{StaticResource FlatButtonStyle}"/>
											<Button Content="Удал." Command="{Binding DataContext.DeleteTransactionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" Background="#BF616A" Foreground="White" FontSize="11" Padding="10,4" Margin="2,0" Style="{StaticResource FlatButtonStyle}"/>
										</StackPanel>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>
						</DataGrid.Columns>
					</DataGrid>
				</Grid>
			</TabItem>

			<TabItem Header="Анализ">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					<TextBlock Text="Распределение расходов по категориям" FontSize="18" FontWeight="SemiBold" Foreground="#2E3440" Margin="0,0,0,12"/>

					<Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16" BorderBrush="#D8DEE9" BorderThickness="1">
						<lvc:PieChart Series="{Binding PieSeries}" LegendLocation="Right" Hoverable="True" InnerRadius="40" Margin="0,0,0,10">
							<lvc:PieChart.ChartLegend>
								<lvc:DefaultLegend BulletSize="16" FontSize="14" Foreground="#2E3440"/>
							</lvc:PieChart.ChartLegend>
							<lvc:PieChart.DataTooltip>
								<lvc:DefaultTooltip BulletSize="16" FontSize="14" Foreground="#2E3440"/>
							</lvc:PieChart.DataTooltip>
						</lvc:PieChart>
					</Border>
				</Grid>
			</TabItem>
		</TabControl>
	</Grid>
</Window>